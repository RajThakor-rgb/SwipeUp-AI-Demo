# Copy to .env.local for local development, or set this in Vercel → Project → Settings → Environment Variables.
# The key is read ONLY on the server (app/api/claude/route.ts). It is never exposed to the browser.
# Until this is set, the app runs in "shell-only" mode: every panel is clickable, but the Claude
# tool shows a clear "AI not connected" message instead of generating/judging.
ANTHROPIC_API_KEY=
